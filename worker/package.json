{
  "name": "newcam-worker",
  "version": "1.0.0",
  "description": "Worker para monitoramento e ativação de câmeras NewCAM",
  "main": "src/worker.js",
  "type": "module",
  "scripts": {
    "start": "node src/worker.js",
    "start:upload": "node src/uploadWorker.js",
    "dev": "nodemon src/worker.js",
    "dev:upload": "nodemon src/uploadWorker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:upload\"",
    "test": "echo \"No tests specified\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "aws-sdk": "^2.1490.0",
    "axios": "^1.6.0",
    "bull": "^4.12.0",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "socket.io-client": "^4.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "worker",
    "camera",
    "monitoring",
    "newcam"
  ],
  "author": "NewCAM Team",
  "license": "MIT"
}