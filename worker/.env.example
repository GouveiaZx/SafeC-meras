# Worker Configuration
BACKEND_URL=http://localhost:3002
WORKER_TOKEN=your-worker-token-here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Wasabi S3 Configuration
WASABI_ACCESS_KEY=your-wasabi-access-key
WASABI_SECRET_KEY=your-wasabi-secret-key
WASABI_BUCKET_NAME=your-bucket-name
WASABI_ENDPOINT=https://s3.wasabisys.com
WASABI_REGION=us-east-1

# Upload Worker Configuration
DELETE_AFTER_UPLOAD=false
LOG_LEVEL=info

# Queue Configuration
UPLOAD_QUEUE_CONCURRENCY=5
UPLOAD_RETRY_ATTEMPTS=3
UPLOAD_RETRY_DELAY=5000