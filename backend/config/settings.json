{
  "system": {
    "name": "NewCAM",
    "version": "1.0.0",
    "timezone": "America/Sao_Paulo",
    "language": "pt-BR"
  },
  "recording": {
    "continuous_enabled": true,
    "segment_duration": 30,
    "max_file_size": 100,
    "retention_days": 30,
    "quality": "high"
  },
  "storage": {
    "local_path": "/storage/recordings",
    "s3_enabled": true,
    "s3_bucket": "newcam-recordings",
    "cleanup_enabled": true,
    "max_storage_gb": 500
  },
  "notifications": {
    "email_enabled": false,
    "email_smtp_host": "",
    "email_smtp_port": 587,
    "email_username": "",
    "email_password": "",
    "webhook_enabled": false,
    "webhook_url": ""
  },
  "security": {
    "session_timeout": 3600,
    "max_login_attempts": 5,
    "password_min_length": 8,
    "require_2fa": false
  }
}